# Whitelabel title used in the manifest, popup and packaged file name.
EXTENSION_TITLE=Zapitu WASession Capture

# Path to a custom icon in PNG or SVG format. SVG icons are rasterized to the
# required sizes automatically during packaging.
# EXTENSION_ICON=./assets/icon.svg

# Comma-separated list of host patterns where the companion app runs.
# The bridge content-script will be injected into these origins.
APP_HOSTS=https://app.example.com/*,https://app2.example.com/*
